@page
@model webtudo.Pages.LoginModel
@{
    ViewData["Title"] = "Entrar";
    Layout = "_LayoutLogin";
}

<section class="login-container">
    <div class="login-card">
        @{
            ViewData["LogoVariant"] = "login";
            ViewData["LogoAsLink"] = false;
        }
        <partial name="_LogoGlass" />

        <h1>Entrar no sistema</h1>
        <p class="login-subtitulo">Area do cliente ou administrativa</p>

        @if (!string.IsNullOrEmpty(Model.MensagemErro))
        {
            <div class="login-erro">@Model.MensagemErro</div>
        }

        <form method="post" class="login-form">
            <div asp-validation-summary="ModelOnly" class="login-erro"></div>

            <div class="campo">
                <label asp-for="Input.Email">E-mail</label>
                <input asp-for="Input.Email" type="email" placeholder="seu@email.com" autocomplete="username" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="campo">
                <label asp-for="Input.Senha">Senha</label>
                <input asp-for="Input.Senha" type="password" placeholder="Sua senha" autocomplete="current-password" />
                <span asp-validation-for="Input.Senha" class="text-danger"></span>
            </div>

            <label class="login-lembrar">
                <input asp-for="Input.LembrarMe" type="checkbox" />
                Lembrar de mim
            </label>

            <button type="submit" class="btn-login">Entrar</button>
        </form>

        <div class="login-areas">
            <div class="login-area-item">
                <strong>Cliente</strong>
                <span>Catalogo e compras</span>
            </div>
            <div class="login-area-item">
                <strong>Administrador</strong>
                <span>Cadastro e atualizacao de produtos</span>
            </div>
        </div>

        <p class="login-demo">
            Demo admin: <code>admin@webtudotech.com</code> / <code>admin123</code><br />
            Demo cliente: <code>cliente@webtudotech.com</code> / <code>cliente123</code>
        </p>

        <a asp-page="/Index" class="login-voltar">Continuar sem login (catalogo)</a>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
