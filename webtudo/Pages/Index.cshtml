@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}
<section class="catalogo-layout">
    <div class="catalogo-conteudo">
        <div class="catalogo-topo">
            <h1>Produtos</h1>
            <select class="select-ordenacao" name="ordenacao">
                <option value="relevancia">Ordenar por: Relevancia</option>
                <option value="menor-preco">Menor preco</option>
                <option value="maior-preco">Maior preco</option>
                <option value="mais-vendidos">Mais vendidos</option>
                <option value="mais-avaliados">Melhor avaliacao</option>
                <option value="mais-recentes">Mais recentes</option>
            </select>
        </div>

        <div class="filtro-rapido">
            <h2>Filtros</h2>
            <form class="filtro-form">
                <div class="filtro-grupo">
                    <label for="precoMin">Preco</label>
                    <div class="filtro-preco">
                        <input id="precoMin" type="number" placeholder="Min" min="0" />
                        <input id="precoMax" type="number" placeholder="Max" min="0" />
                    </div>
                </div>

                <div class="filtro-grupo">
                    <label for="marca">Marca</label>
                    <select id="marca">
                        <option>Todas</option>
                        <option>Apple</option>
                        <option>Samsung</option>
                        <option>Sony</option>
                    </select>
                </div>

                <div class="filtro-grupo">
                    <label for="avaliacao">Avaliacao minima</label>
                    <select id="avaliacao">
                        <option>Qualquer</option>
                        <option>4 estrelas ou mais</option>
                        <option>4.5 estrelas ou mais</option>
                    </select>
                </div>

                <div class="filtro-checks">
                    <label><input type="checkbox" /> Frete gratis</label>
                    <label><input type="checkbox" /> Full / Entrega rapida</label>
                    <label><input type="checkbox" /> Produto novo</label>
                    <label><input type="checkbox" /> Em estoque</label>
                </div>

                <button type="button" class="btn-aplicar-filtro">Aplicar filtros</button>
            </form>
        </div>

        <div class="produtos-container">

    <div class="produto-card">
        <img src="data:image/webp;base64," width="180" />
        <h2> Iphone 14 Pro Max</h2>
        <p> Preço: R$ 7.500</p>
        <a asp-page="/comprar" asp-route-nome="Iphone 14 Pro Max" asp-route-preco="7.500" class="btn-comprar">Comprar</a>
    </div>

    <div class="produto-card">
        <img src="data:image/webp;base64," width="180" />
        <h2> Iphone 17 Pro Max</h2>
        <p> Preço: R$ 10, 500</p>
        <a asp-page="/comprar" asp-route-nome="Iphone 17 Pro Max" asp-route-preco="10.500" class="btn-comprar">Comprar</a>
    </div>

    <div class="produto-card">
        <img src="https://encrypted-tbn3.gstatic.com/shopping?q=tbn:ANd9GcTQj_yjt4n5d9pmboteNKWpbqZX9FmYHHyCOXJnj1_vyrqisjVPACUcNLu_1VlZzGiWmoUZrDYFNUNKizrN4qeEpqjoPcnEVxKjD9LQBI06pf9ISjCtVIl6GyqbZaxfMK_t8KYlstrA9lc&usqp=CAc" width="180" />
        <h2> samsung galaxy s25 ultra</h2>
        <p> Preço: R$ 9, 000</p>
        <a asp-page="/comprar" asp-route-nome="Samsung Galaxy S25 Ultra" asp-route-preco="9.000" class="btn-comprar">Comprar</a>
    </div>

    <div class="produto-card">
        <img src="data:image/jpeg;base64," width="180" />
        <h2> Sony PlayStation - Game console</h2>
        <p> Preço:R$ 1.426</p>
        <a asp-page="/comprar" asp-route-nome="Sony PlayStation - Game console" asp-route-preco="1.426" class="btn-comprar">Comprar</a>
    </div>

    <div class="produto-card">
        <img src="data:image/webp;base64," width="180" />
        <h2> Console PlayStation 4 1TB Edição Limitada Days Of Play - Cinza</h2>
        <p> Preço:R$3.599</p>
        <a asp-page="/comprar" asp-route-nome="Console PlayStation 4 1TB Edição Limitada" asp-route-preco="3.599" class="btn-comprar">Comprar</a>
    </div>

    <div class="produto-card">
        <img src="https://encrypted-tbn0.gstatic.com/shopping?q=tbn:ANd9GcQD7IcB7WVDclIxTqmCYDKbn1mtAr_2D7J5aWMIRsFIdyXxLJapw7hawHj0SgLK_fd2ZcTjorZUxtThiX4fBYy9PRq1QdzEzmaXPh_7duINFij-G9YBm-yM_RI3qU5nJPANyfUa0Q&usqp=CAc" width="180" />
        <h2> Console PlayStation 5</h2>
        <p> Preço: R$4.235, 35</p>
        <a asp-page="/comprar" asp-route-nome="Console PlayStation 5" asp-route-preco="4.235,35" class="btn-comprar">Comprar</a>
    </div>
        </div>
    </div>

    <aside class="categorias-lateral">
        <h2>Categorias</h2>
        <table class="categorias-tabela">
            <thead>
                <tr>
                    <th>Categoria</th>
                    <th>Qtd</th>
                </tr>
            </thead>
            <tbody>
                <tr><td>Celulares</td><td>3</td></tr>
                <tr><td>Consoles</td><td>3</td></tr>
                <tr><td>Acessorios</td><td>2</td></tr>
                <tr><td>Informatica</td><td>1</td></tr>
                <tr><td>Ofertas</td><td>4</td></tr>
            </tbody>
        </table>
    </aside>
</section>