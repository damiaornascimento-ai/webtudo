@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
    string Chk(bool value) => value ? "checked" : "";
    var ordenacoes = new (string Value, string Label)[]
    {
        ("relevancia", "Ordenar por: Relevancia"),
        ("menor-preco", "Menor preco"),
        ("maior-preco", "Maior preco"),
        ("mais-vendidos", "Mais vendidos"),
        ("mais-avaliados", "Melhor avaliacao"),
        ("mais-recentes", "Mais recentes")
    };
    var avaliacoes = new (string Value, string Label)[]
    {
        ("", "Qualquer"),
        ("4", "4 estrelas ou mais"),
        ("4.5", "4.5 estrelas ou mais")
    };
}
<section class="catalogo-layout">
    <div class="catalogo-conteudo">
        <div class="catalogo-topo">
            <h1>Produtos @(string.IsNullOrWhiteSpace(Model.Categoria) ? "" : $"— {Model.Categoria}")</h1>
            <select class="select-ordenacao" name="ordenacao" form="formFiltros" onchange="document.getElementById('formFiltros').submit()">
                @foreach (var item in ordenacoes)
                {
                    if (Model.Ordenacao == item.Value)
                    {
                        <option value="@item.Value" selected>@item.Label</option>
                    }
                    else
                    {
                        <option value="@item.Value">@item.Label</option>
                    }
                }
            </select>
        </div>

        <div class="produtos-container">
            @if (Model.Produtos.Count == 0)
            {
                <p class="catalogo-vazio">Nenhum produto encontrado com os filtros selecionados.</p>
            }
            else
            {
                @foreach (var produto in Model.Produtos)
                {
                    <article class="produto-card">
                        <img src="@Model.ObterImagem(produto)" alt="@produto.Nome" loading="lazy" />
                        <span class="produto-categoria">@produto.Categoria</span>
                        <h2>@produto.Nome</h2>
                        <p class="produto-preco">R$ @produto.PrecoCompra</p>
                        <p class="produto-avaliacao">★ @produto.Avaliacao.ToString("0.0") · @produto.Marca</p>
                        @if (!string.IsNullOrWhiteSpace(produto.DescricaoResumo))
                        {
                            <p class="produto-resumo">@produto.DescricaoResumo</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(produto.DescricaoCompleta))
                        {
                            <details class="produto-detalhes">
                                <summary>Ver informacoes completas</summary>
                                <div class="produto-detalhes-conteudo">
                                    <p>@produto.DescricaoCompleta</p>
                                    <ul class="produto-tags">
                                        @if (produto.FreteGratis) { <li>Frete gratis</li> }
                                        @if (produto.EntregaRapida) { <li>Entrega rapida</li> }
                                        @if (produto.ProdutoNovo) { <li>Lancamento</li> }
                                        @if (produto.EmEstoque) { <li>Em estoque</li> }
                                    </ul>
                                </div>
                            </details>
                        }
                        <a asp-page="/comprar" asp-route-nome="@produto.Nome" asp-route-preco="@produto.PrecoCompra" class="btn-comprar">Comprar</a>
                    </article>
                }
            }
        </div>
    </div>

    <aside class="categorias-lateral">
        <h2>Categorias</h2>
        <table class="categorias-tabela">
            <thead>
                <tr>
                    <th>Categoria</th>
                    <th>Qtd</th>
                </tr>
            </thead>
            <tbody>
                <tr class="@(string.IsNullOrWhiteSpace(Model.Categoria) ? "categoria-ativa" : "")">
                    <td>
                        <a class="categoria-link" asp-page="/Index" asp-route-ordenacao="@Model.Ordenacao">Todas</a>
                    </td>
                    <td>@Model.Categorias.Sum(c => c.Quantidade)</td>
                </tr>
                @foreach (var cat in Model.Categorias)
                {
                    <tr class="@(Model.CategoriaAtiva(cat.Nome) ? "categoria-ativa" : "")">
                        <td>
                            <a class="categoria-link" href="@Model.LinkCategoria(cat.Nome)">@cat.Nome</a>
                        </td>
                        <td>@cat.Quantidade</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="filtro-rapido filtro-lateral">
            <h2>Filtros</h2>
            <form method="get" id="formFiltros" class="filtro-form">
                <input type="hidden" name="categoria" value="@Model.Categoria" />

                <div class="filtro-grupo">
                    <label for="precoMin">Preco</label>
                    <div class="filtro-preco">
                        <input id="precoMin" name="precoMin" type="number" placeholder="Min" min="0" step="0.01" value="@(Model.PrecoMin?.ToString(System.Globalization.CultureInfo.InvariantCulture))" />
                        <input id="precoMax" name="precoMax" type="number" placeholder="Max" min="0" step="0.01" value="@(Model.PrecoMax?.ToString(System.Globalization.CultureInfo.InvariantCulture))" />
                    </div>
                </div>

                <div class="filtro-grupo">
                    <label for="marca">Marca</label>
                    <select id="marca" name="marca">
                        @foreach (var marca in Model.MarcasDisponiveis)
                        {
                            var marcaAtiva = (string.IsNullOrWhiteSpace(Model.Marca) && marca == "Todas") || Model.Marca == marca;
                            if (marcaAtiva)
                            {
                                <option value="@marca" selected>@marca</option>
                            }
                            else
                            {
                                <option value="@marca">@marca</option>
                            }
                        }
                    </select>
                </div>

                <div class="filtro-grupo">
                    <label for="avaliacao">Avaliacao minima</label>
                    <select id="avaliacao" name="avaliacao">
                        @foreach (var item in avaliacoes)
                        {
                            if ((Model.Avaliacao ?? "") == item.Value)
                            {
                                <option value="@item.Value" selected>@item.Label</option>
                            }
                            else
                            {
                                <option value="@item.Value">@item.Label</option>
                            }
                        }
                    </select>
                </div>

                <div class="filtro-checks">
                    <label><input type="checkbox" name="freteGratis" value="true" @Chk(Model.FreteGratis) /> Frete gratis</label>
                    <label><input type="checkbox" name="entregaRapida" value="true" @Chk(Model.EntregaRapida) /> Entrega rapida</label>
                    <label><input type="checkbox" name="produtoNovo" value="true" @Chk(Model.ProdutoNovo) /> Produto novo</label>
                    <label><input type="checkbox" name="emEstoque" value="true" @Chk(Model.EmEstoque) /> Em estoque</label>
                </div>

                <button type="submit" class="btn-aplicar-filtro">Aplicar</button>
                <a asp-page="/Index" class="btn-limpar-filtro">Limpar filtros</a>
            </form>
        </div>
    </aside>
</section>
