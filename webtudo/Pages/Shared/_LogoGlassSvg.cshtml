<svg class="logo-glass-svg" viewBox="0 0 248 52" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Webtudo Tech">
    <defs>
        <linearGradient id="logoGlassFill" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="rgba(255,255,255,0.62)" />
            <stop offset="50%" stop-color="rgba(255,255,255,0.28)" />
            <stop offset="100%" stop-color="rgba(200,230,255,0.22)" />
        </linearGradient>
        <linearGradient id="logoIconGrad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#6ec8ef" />
            <stop offset="100%" stop-color="#1a6fa8" />
        </linearGradient>
        <linearGradient id="logoTextGrad" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#0e3552" />
            <stop offset="100%" stop-color="#1a6fa8" />
        </linearGradient>
        <filter id="logoGlow" x="-20%" y="-20%" width="140%" height="140%">
            <feDropShadow dx="0" dy="2" stdDeviation="2" flood-color="rgba(8,45,82,0.22)" />
        </filter>
    </defs>

    <rect x="1" y="1" width="246" height="50" rx="14" fill="url(#logoGlassFill)" stroke="rgba(255,255,255,0.75)" stroke-width="1.4" filter="url(#logoGlow)" />
    <rect x="2" y="2" width="244" height="22" rx="13" fill="rgba(255,255,255,0.38)" />

    <g transform="translate(10, 9)">
        <rect x="0" y="0" width="34" height="34" rx="10" fill="url(#logoIconGrad)" />
        <rect x="0.5" y="0.5" width="33" height="14" rx="10" fill="rgba(255,255,255,0.42)" />
        <path d="M17 8 L23 14 L17 20 L11 14 Z" fill="rgba(255,255,255,0.95)" />
        <circle cx="17" cy="26" r="2.5" fill="rgba(255,255,255,0.9)" />
        <path d="M9 26 H25" stroke="rgba(255,255,255,0.55)" stroke-width="1.4" stroke-linecap="round" />
    </g>

    <text x="54" y="24" fill="url(#logoTextGrad)" font-family="Segoe UI, Arial, sans-serif" font-size="17" font-weight="700" letter-spacing="0.2">Webtudo</text>
    <text x="54" y="40" fill="#2f89c7" font-family="Segoe UI, Arial, sans-serif" font-size="11" font-weight="700" letter-spacing="2.6">TECH</text>
</svg>
