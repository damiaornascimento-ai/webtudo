<!DOCTYPE html>

<html lang="pt-BR">

<head>

    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Webtudo Tech</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/webtudo.styles.css" asp-append-version="true" />

</head>

<body>

    <header>

        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">

            <div class="container">

                <div class="navbar-brand brand-webtudo-tech p-0 m-0">
                    @{
                        ViewData["LogoVariant"] = "navbar";
                        ViewData["LogoAsLink"] = true;
                    }
                    <partial name="_LogoGlass" />
                </div>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"

                        aria-expanded="false" aria-label="Toggle navigation">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1">

                        <li class="nav-item">

                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Inicio</a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Produtos</a>

                        </li>

                        @if (User.IsInRole("Administrador"))

                        {

                            <li class="nav-item">

                                <a class="nav-link text-dark nav-admin" asp-area="" asp-page="/Admin/Index">Administracao</a>

                            </li>

                        }

                    </ul>

                    <ul class="navbar-nav">

                        @if (User.Identity?.IsAuthenticated == true)

                        {

                            <li class="nav-item">

                                <span class="nav-link text-dark nav-usuario">Ola, @User.Identity.Name</span>

                            </li>

                            @if (User.IsInRole("Cliente"))

                            {

                                <li class="nav-item">

                                    <span class="nav-link text-muted nav-badge-cliente">Area cliente</span>

                                </li>

                            }

                            <li class="nav-item">

                                <a class="nav-link text-dark" asp-area="" asp-page="/Logout">Sair</a>

                            </li>

                        }

                        else

                        {

                            <li class="nav-item">

                                <a class="nav-link text-dark fw-semibold" asp-area="" asp-page="/Login">Entrar</a>

                            </li>

                        }

                    </ul>

                </div>

            </div>

        </nav>

    </header>

    <div class="container">

        <main role="main" class="pb-3">

            @RenderBody()

        </main>

    </div>



    <footer class="border-top footer text-muted">

        <div class="container">

            &copy; 2026 - Webtudo Tech - <a asp-area="" asp-page="/Privacy">Privacidade</a>

        </div>

    </footer>



    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>



    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>

